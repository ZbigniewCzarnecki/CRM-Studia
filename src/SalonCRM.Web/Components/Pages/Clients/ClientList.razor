@page "/clients"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IClientService ClientService
@inject ILoyaltyService LoyaltyService
@inject ISettingsService SettingsService
@inject IJSRuntime JS
@inject IPermissionService PermService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Klienci — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Klienci</h1>
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ExportCsv">Eksportuj CSV</button>
        <label for="csv-import-input" class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer">Importuj CSV</label>
        <InputFile id="csv-import-input" accept=".csv" style="display:none" OnChange="ImportCsv" />
        @if (_canCreate)
        {
            <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Dodaj klienta</button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_importResult))
{
    <div class="alert alert-info alert-dismissible">@_importResult
        <button type="button" class="btn-close" @onclick="() => _importResult = null"></button>
    </div>
}

<div class="search-bar mb-3">
    <input class="form-control" placeholder="Szukaj po imieniu, nazwisku, emailu..."
           @bind="_query" @bind:event="oninput" @bind:after="OnSearch" />
</div>

@if (_loading)
{
    <div class="text-center py-4"><span class="spinner-border text-primary"></span></div>
}
else if (!_clients.Any())
{
    <div class="empty-state">Brak klientów. Dodaj pierwszego!</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Imię i nazwisko</th>
                        <th>Telefon</th>
                        <th>Email</th>
                        <th>Pieczątki</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _clients)
                    {
                        <tr>
                            <td>
                                <div>@c.FirstName @c.LastName</div>
                                @if (!string.IsNullOrWhiteSpace(c.Notes))
                                {
                                    <small class="text-muted" title="@c.Notes"><i class="bi bi-journal-text me-1"></i>@(c.Notes.Length > 50 ? c.Notes[..50] + "…" : c.Notes)</small>
                                }
                            </td>
                            <td>@c.PhoneNumber</td>
                            <td>
                                <div>@c.Email
                                    @if (c.ConsentEmail || c.ConsentSms)
                                    {
                                        <span class="ms-1 consent-indicators">
                                            @if (c.ConsentEmail) { <i class="bi bi-envelope-fill" title="Zgoda e-mail"></i> }
                                            @if (c.ConsentSms)   { <i class="bi bi-phone-fill" title="Zgoda SMS"></i> }
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                @{
                                    var count = _stampCounts.TryGetValue(c.Id, out var sc) ? sc : 0;
                                    var dots = Math.Min(_stampsForReward, 10);
                                }
                                <div class="stamps-cell">
                                    <div class="stamp-dots" title="@count / @_stampsForReward pieczątek">
                                        @for (int i = 0; i < dots; i++)
                                        {
                                            <span class="sdot @(i < count ? "sdot-on" : "")"></span>
                                        }
                                        @if (_stampsForReward > 10)
                                        {
                                            <span class="stamp-count-label">@count/@_stampsForReward</span>
                                        }
                                    </div>
                                    @if (_canManageLoyalty)
                                    {
                                        <button class="stamp-add-btn" title="Dodaj pieczątkę" @onclick="() => OpenQuickStamp(c)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                            <td class="text-end">
                                <a href="/clients/@c.Id" class="btn btn-sm btn-outline-info me-1">Profil</a>
                                @if (_canEditAll || c.CreatedByUserId == _currentUserId)
                                {
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenForm(c)">Edytuj</button>
                                }
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenNotes(c)">Notatki</button>
                                @if (_canEditAll)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(c)">Usuń</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showForm)
{
    <ClientForm Client="_editing" OnSaved="OnSaved" OnCancelled="CloseForm" />
}

@if (_showNotes && _notesClient != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>Notatki — @_notesClient.FirstName @_notesClient.LastName</h5>
                <button class="btn-close" @onclick="CloseNotes"></button>
            </div>
            <div class="modal-body-custom">
                <textarea class="form-control" rows="6" @bind="_notesText"
                          placeholder="Alergie, preferencje, uwagi medyczne..."></textarea>
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-primary" @onclick="SaveNotes">Zapisz notatki</button>
                <button class="btn btn-secondary ms-2" @onclick="CloseNotes">Anuluj</button>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm && _toDelete != null)
{
    <div class="modal-backdrop">
        <div class="confirm-dialog">
            <p>Usunąć klienta <strong>@_toDelete.FirstName @_toDelete.LastName</strong>?</p>
            <button class="btn btn-danger me-2" @onclick="ExecuteDelete">Usuń</button>
            <button class="btn btn-secondary" @onclick="() => _showDeleteConfirm = false">Anuluj</button>
        </div>
    </div>
}

@if (_showQuickStamp && _stampClient != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>Dodaj pieczątkę — @_stampClient.FirstName @_stampClient.LastName</h5>
                <button class="btn-close" @onclick="CloseQuickStamp"></button>
            </div>
            <div class="modal-body-custom">
                <label class="form-label">Notatka (opcjonalnie)</label>
                <input class="form-control" @bind="_stampNote" placeholder="np. urodziny, akcja promocyjna..." />
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-primary" @onclick="ConfirmQuickStamp">Dodaj pieczątkę</button>
                <button class="btn btn-secondary ms-2" @onclick="CloseQuickStamp">Anuluj</button>
            </div>
        </div>
    </div>
}

@if (_stampAdded)
{
    <div class="toast-notification">
        <i class="bi bi-star-fill me-2" style="color:var(--salon-pink)"></i>Pieczątka dodana!
    </div>
}

@code {
    private List<ClientEntity> _clients = [];
    private Dictionary<int, int> _stampCounts = [];
    private int _stampsForReward = 10;
    private string _query = string.Empty;
    private bool _loading = true;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private bool _showNotes;
    private bool _showQuickStamp;
    private bool _stampAdded;
    private ClientEntity? _editing;
    private ClientEntity? _toDelete;
    private ClientEntity? _notesClient;
    private ClientEntity? _stampClient;
    private string _notesText = string.Empty;
    private string _stampNote = string.Empty;
    private string? _importResult;
    private string _currentUserId = string.Empty;
    private bool _canCreate;
    private bool _canEditAll;
    private bool _canManageLoyalty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _canCreate = await PermService.HasAsync(user, Permission.CreateClients);
        _canEditAll = await PermService.HasAsync(user, Permission.EditClientData);
        _canManageLoyalty = await PermService.HasAsync(user, Permission.ManageLoyaltyCards);
        var settings = await SettingsService.GetAsync();
        _stampsForReward = settings.LoyaltyStampsForReward;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _clients = string.IsNullOrWhiteSpace(_query)
            ? await ClientService.GetAllAsync()
            : await ClientService.SearchAsync(_query);
        _stampCounts = [];
        foreach (var c in _clients)
            _stampCounts[c.Id] = await LoyaltyService.CountAsync(c.Id);
        _loading = false;
    }

    private async Task OnSearch() => await LoadAsync();

    private async Task ExportCsv()
    {
        var all = await ClientService.GetAllAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Id;Imie;Nazwisko;Telefon;Email;Notatki");
        foreach (var c in all)
            sb.AppendLine($"{c.Id};{CsvQ(c.FirstName)};{CsvQ(c.LastName)};{CsvQ(c.PhoneNumber)};{CsvQ(c.Email)};{CsvQ(c.Notes)}");
        var bytes = new System.Text.UTF8Encoding(true).GetBytes(sb.ToString());
        await JS.InvokeVoidAsync("downloadCsv", "klienci.csv", Convert.ToBase64String(bytes));
    }

    private async Task ImportCsv(InputFileChangeEventArgs e)
    {
        using var reader = new System.IO.StreamReader(
            e.File.OpenReadStream(maxAllowedSize: 5_000_000),
            new System.Text.UTF8Encoding(true));
        var content = await reader.ReadToEndAsync();
        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries).Skip(1);
        int added = 0, skipped = 0;
        var existing = (await ClientService.GetAllAsync()).Select(c => c.Email.ToLower()).ToHashSet();
        foreach (var rawLine in lines)
        {
            var parts = rawLine.Trim('\r').Split(';');
            if (parts.Length < 5) continue;
            var email = Unq(parts[4]);
            if (string.IsNullOrWhiteSpace(email) || existing.Contains(email.ToLower())) { skipped++; continue; }
            await ClientService.CreateAsync(new ClientEntity
            {
                FirstName = Unq(parts[1]), LastName = Unq(parts[2]),
                PhoneNumber = Unq(parts[3]), Email = email,
                Notes = parts.Length > 5 ? Unq(parts[5]) : "",
                CreatedByUserId = _currentUserId
            });
            added++;
        }
        _importResult = $"Zaimportowano: {added}, pominięto (duplikaty): {skipped}";
        await LoadAsync();
    }

    private static string Unq(string s) => s.Trim().Trim('"');
    private static string CsvQ(string v) => "\"" + v.Replace("\"", "\"\"") + "\"";

    private void OpenForm(ClientEntity? client)
    {
        _editing = client == null
            ? new ClientEntity { CreatedByUserId = _currentUserId }
            : new ClientEntity
            {
                Id = client.Id, FirstName = client.FirstName, LastName = client.LastName,
                PhoneNumber = client.PhoneNumber, Email = client.Email, Notes = client.Notes,
                CreatedByUserId = client.CreatedByUserId,
                ConsentEmail = client.ConsentEmail, ConsentSms = client.ConsentSms
            };
        _showForm = true;
    }

    private void OpenNotes(ClientEntity c)
    {
        _notesClient = c;
        _notesText = c.Notes;
        _showNotes = true;
    }

    private void CloseNotes() { _showNotes = false; _notesClient = null; }

    private async Task SaveNotes()
    {
        if (_notesClient == null) return;
        var updated = new ClientEntity
        {
            Id = _notesClient.Id, FirstName = _notesClient.FirstName, LastName = _notesClient.LastName,
            PhoneNumber = _notesClient.PhoneNumber, Email = _notesClient.Email, Notes = _notesText,
            ConsentEmail = _notesClient.ConsentEmail, ConsentSms = _notesClient.ConsentSms
        };
        await ClientService.UpdateAsync(updated);
        _showNotes = false;
        _notesClient = null;
        await LoadAsync();
    }

    private void OpenQuickStamp(ClientEntity c)
    {
        _stampClient = c;
        _stampNote = string.Empty;
        _showQuickStamp = true;
    }

    private void CloseQuickStamp()
    {
        _showQuickStamp = false;
        _stampClient = null;
    }

    private async Task ConfirmQuickStamp()
    {
        if (_stampClient == null) return;
        await LoyaltyService.AddStampAsync(_stampClient.Id, null, _currentUserId, _stampNote, true);
        _stampCounts[_stampClient.Id] = await LoyaltyService.CountAsync(_stampClient.Id);
        _showQuickStamp = false;
        _stampClient = null;
        _stampAdded = true;
        StateHasChanged();
        await Task.Delay(2000);
        _stampAdded = false;
    }

    private void CloseForm() => _showForm = false;
    private async Task OnSaved() { _showForm = false; await LoadAsync(); }
    private void ConfirmDelete(ClientEntity c) { _toDelete = c; _showDeleteConfirm = true; }
    private async Task ExecuteDelete()
    {
        if (_toDelete != null) await ClientService.DeleteAsync(_toDelete.Id);
        _showDeleteConfirm = false;
        await LoadAsync();
    }
}
