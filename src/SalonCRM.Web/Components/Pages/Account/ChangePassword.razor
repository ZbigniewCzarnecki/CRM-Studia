@page "/account/password"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject Microsoft.AspNetCore.Identity.UserManager<SalonCRM.Web.Data.ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Zmiana hasła — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Zmiana hasła</h1>
</div>

<div class="card" style="max-width:460px">
    <div class="card-body p-4">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mb-3">@_error</div>
        }
        @if (_success)
        {
            <div class="alert alert-success mb-3">Hasło zostało zmienione.</div>
        }
        <div class="mb-3">
            <label class="form-label">Aktualne hasło</label>
            <input type="password" class="form-control" @bind="_current" @bind:event="oninput" />
        </div>
        <div class="mb-3">
            <label class="form-label">Nowe hasło</label>
            <input type="password" class="form-control" @bind="_new" @bind:event="oninput" />
        </div>
        <div class="mb-3">
            <label class="form-label">Potwierdź nowe hasło</label>
            <input type="password" class="form-control" @bind="_confirm" @bind:event="oninput" />
        </div>
        <button class="btn btn-primary w-100" @onclick="Change" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Zmień hasło
        </button>
    </div>
</div>

@code {
    private string _current = "";
    private string _new = "";
    private string _confirm = "";
    private string? _error;
    private bool _success;
    private bool _loading;

    private async Task Change()
    {
        _error = null;
        _success = false;

        if (string.IsNullOrWhiteSpace(_current) || string.IsNullOrWhiteSpace(_new))
        { _error = "Wypełnij wszystkie pola."; return; }

        if (_new != _confirm)
        { _error = "Nowe hasła nie są identyczne."; return; }

        _loading = true;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId == null) { _loading = false; return; }

        var user = await UserManager.FindByIdAsync(userId);
        if (user == null) { _loading = false; return; }

        var result = await UserManager.ChangePasswordAsync(user, _current, _new);
        _loading = false;

        if (result.Succeeded)
        {
            _success = true;
            _current = _new = _confirm = "";
        }
        else
        {
            _error = result.Errors.FirstOrDefault()?.Description ?? "Nie udało się zmienić hasła.";
        }
    }
}
