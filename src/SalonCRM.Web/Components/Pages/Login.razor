@page "/login"
@layout SalonCRM.Web.Components.Layout.EmptyLayout

<PageTitle>Logowanie — SalonCRM</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">💅 SalonCRM</div>
        <h2>Zaloguj się</h2>

        @if (Error == "1")
        {
            <div class="alert alert-danger">Nieprawidłowy email lub hasło.</div>
        }

        <form method="post" action="/auth/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" autocomplete="username" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Hasło</label>
                <input type="password" name="password" class="form-control" autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Zaloguj</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
}
