@page "/login"
@layout SalonCRM.Web.Components.Layout.EmptyLayout
@inject SignInManager<SalonCRM.Web.Data.ApplicationUser> SignInManager
@inject NavigationManager Nav

<PageTitle>Logowanie — SalonCRM</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">💅 SalonCRM</div>
        <h2>Zaloguj się</h2>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText @bind-Value="_model.Email" class="form-control" autocomplete="username" />
                <ValidationMessage For="() => _model.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Hasło</label>
                <InputText @bind-Value="_model.Password" type="password" class="form-control" autocomplete="current-password" />
                <ValidationMessage For="() => _model.Password" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Zaloguj</button>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private LoginModel _model = new();
    private string? _error;

    private async Task HandleLogin()
    {
        var result = await SignInManager.PasswordSignInAsync(_model.Email, _model.Password, isPersistent: false, lockoutOnFailure: false);
        if (result.Succeeded)
            Nav.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        else
            _error = "Nieprawidłowy email lub hasło.";
    }

    private sealed class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }
}
