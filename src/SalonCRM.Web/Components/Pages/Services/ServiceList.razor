@page "/services"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IServiceCrmService ServiceCrmService

<PageTitle>Usługi — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Usługi</h1>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Dodaj usługę</button>
</div>

<div class="search-bar mb-3">
    <input class="form-control" placeholder="Szukaj po nazwie lub opisie..."
           @bind="_query" @bind:event="oninput" @bind:after="OnSearch" />
</div>

@if (_loading)
{
    <div class="text-center py-4"><span class="spinner-border text-primary"></span></div>
}
else if (!_services.Any())
{
    <div class="empty-state">Brak usług. Dodaj pierwszą!</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nazwa</th>
                        <th>Czas</th>
                        <th class="text-end">Cena</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _services)
                    {
                        <tr>
                            <td>
                                <div>@s.Name</div>
                                <small class="text-muted">@s.Description</small>
                            </td>
                            <td>@s.DurationMinutes min</td>
                            <td class="text-end">@s.Price.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenForm(s)">Edytuj</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(s)">Usuń</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showForm)
{
    <ServiceForm Service="_editing" OnSaved="OnSaved" OnCancelled="CloseForm" />
}

@if (_showDeleteConfirm && _toDelete != null)
{
    <div class="modal-backdrop">
        <div class="confirm-dialog">
            <p>Usunąć usługę <strong>@_toDelete.Name</strong>?</p>
            <button class="btn btn-danger me-2" @onclick="ExecuteDelete">Usuń</button>
            <button class="btn btn-secondary" @onclick="() => _showDeleteConfirm = false">Anuluj</button>
        </div>
    </div>
}

@code {
    private List<ServiceEntity> _services = [];
    private string _query = string.Empty;
    private bool _loading = true, _showForm, _showDeleteConfirm;
    private ServiceEntity? _editing, _toDelete;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _services = string.IsNullOrWhiteSpace(_query)
            ? await ServiceCrmService.GetAllAsync()
            : await ServiceCrmService.SearchAsync(_query);
        _loading = false;
    }

    private async Task OnSearch() => await LoadAsync();
    private void OpenForm(ServiceEntity? s) { _editing = s == null ? new() : new() { Id = s.Id, Name = s.Name, Description = s.Description, DurationMinutes = s.DurationMinutes, Price = s.Price }; _showForm = true; }
    private void CloseForm() => _showForm = false;
    private async Task OnSaved() { _showForm = false; await LoadAsync(); }
    private void ConfirmDelete(ServiceEntity s) { _toDelete = s; _showDeleteConfirm = true; }
    private async Task ExecuteDelete() { if (_toDelete != null) await ServiceCrmService.DeleteAsync(_toDelete.Id); _showDeleteConfirm = false; await LoadAsync(); }
}
