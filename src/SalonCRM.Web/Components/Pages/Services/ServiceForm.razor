@inject IServiceCrmService ServiceCrmService

<div class="modal-backdrop">
    <div class="modal-dialog-custom">
        <div class="modal-header-custom">
            <h5>@(Service.Id == 0 ? "Nowa usługa" : "Edytuj usługę")</h5>
            <button class="btn-close" @onclick="OnCancelled"></button>
        </div>
        <EditForm Model="Service" OnValidSubmit="Save" FormName="service-form">
            <DataAnnotationsValidator />
            <div class="modal-body-custom">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nazwa *</label>
                        <InputText @bind-Value="Service.Name" class="form-control" />
                        <ValidationMessage For="() => Service.Name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Kategoria</label>
                        <InputText @bind-Value="Service.Category" class="form-control" placeholder="np. Masaż, Depilacja, Paznokcie" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Opis</label>
                        <InputTextArea @bind-Value="Service.Description" class="form-control" rows="2" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Czas trwania (min) *</label>
                        <InputNumber @bind-Value="Service.DurationMinutes" class="form-control" />
                        <ValidationMessage For="() => Service.DurationMinutes" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cena (PLN) *</label>
                        <InputNumber @bind-Value="Service.Price" class="form-control" />
                        <ValidationMessage For="() => Service.Price" />
                    </div>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="submit" class="btn btn-primary">Zapisz</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="OnCancelled">Anuluj</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ServiceEntity Service { get; set; } = new();
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    private async Task Save()
    {
        if (Service.Id == 0) await ServiceCrmService.CreateAsync(Service);
        else await ServiceCrmService.UpdateAsync(Service);
        await OnSaved.InvokeAsync();
    }
}
