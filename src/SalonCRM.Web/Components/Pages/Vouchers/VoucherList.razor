@page "/vouchery"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IVoucherService VoucherService
@inject IClientService ClientService
@inject IServiceCrmService ServiceCrmService
@inject IMembershipService MembershipService

<PageTitle>Vouchery — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Vouchery</h1>
    <button class="btn btn-primary" @onclick="OpenCreate">
        <i class="bi bi-plus-lg me-1"></i>Nowy voucher
    </button>
</div>

@if (_expiringCount > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mt-3">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span><strong>@_expiringCount</strong> voucher(y) wygasa w ciągu 7 dni!</span>
    </div>
}

<div class="card mt-3">
    <div class="card-header d-flex flex-wrap gap-2 align-items-center justify-content-between">
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm @(_filter == "all" ? "btn-primary" : "btn-outline-primary")" @onclick='() => _filter = "all"'>Wszystkie</button>
            <button class="btn btn-sm @(_filter == "active" ? "btn-success" : "btn-outline-success")" @onclick='() => _filter = "active"'>Aktywne</button>
            <button class="btn btn-sm @(_filter == "used" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => _filter = "used"'>Użyte</button>
            <button class="btn btn-sm @(_filter == "expired" ? "btn-dark" : "btn-outline-dark")" @onclick='() => _filter = "expired"'>Wygasłe</button>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">Sortuj:</span>
            <select class="form-select form-select-sm" style="width:auto" @bind="_sortBy">
                <option value="date">Data ważności</option>
                <option value="client">Klient (A-Z)</option>
                <option value="code">Kod</option>
                <option value="balance">Saldo</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSort" title="@(_sortDesc ? "Malejąco" : "Rosnąco")">
                <i class="bi bi-sort-@(_sortDesc ? "down" : "up")"></i>
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="p-4 text-center text-muted">Ładowanie...</div>
        }
        else if (!Filtered.Any())
        {
            <div class="p-4 text-center text-muted">Brak voucherów do wyświetlenia.</div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Kod</th>
                        <th>Klient</th>
                        <th>Typ</th>
                        <th>Wartość / Saldo</th>
                        <th>Ważny do</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Filtered)
                    {
                        <tr>
                            <td><code>@v.Code</code></td>
                            <td>@v.RecipientName</td>
                            <td>@(v.Type == VoucherType.Amount ? "Kwotowy" : "Na usługę")</td>
                            <td>
                                @if (v.Type == VoucherType.Amount)
                                {
                                    @if (v.RemainingAmount.HasValue && v.RemainingAmount != v.AmountValue)
                                    {
                                        <span class="@(v.RemainingAmount > 0 ? "" : "text-muted")">@v.RemainingAmount?.ToString("F0") PLN</span>
                                        <span class="text-muted small ms-1">(z @v.AmountValue?.ToString("F0") PLN)</span>
                                    }
                                    else
                                    {
                                        <span>@v.AmountValue?.ToString("F0") PLN</span>
                                    }
                                }
                                else
                                {
                                    @(string.IsNullOrEmpty(v.ServiceName) ? "—" : v.ServiceName)
                                }
                            </td>
                            <td>
                                @v.ExpiresAt.ToString("dd.MM.yyyy")
                                @if (v.IsActive && v.DaysUntilExpiry <= 7)
                                {
                                    <span class="badge bg-warning text-dark ms-1">@v.DaysUntilExpiry dni</span>
                                }
                            </td>
                            <td>
                                @if (v.IsUsed)
                                {
                                    <span class="badge bg-secondary">Użyty</span>
                                }
                                else if (v.IsExpired)
                                {
                                    <span class="badge bg-secondary">Wygasły</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Aktywny</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-outline-info me-1" @onclick="() => OpenHistory(v)" title="Historia użycia">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenEdit(v)">Edytuj</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(v)">Usuń</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Modal: historia użycia -->
@if (_historyVoucher != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom" style="max-width:680px">
            <div class="modal-header-custom">
                <h5>
                    Historia vouchera <code>@_historyVoucher.Code</code>
                    <span class="text-muted fw-normal ms-2 fs-6">(@_historyVoucher.RecipientName)</span>
                </h5>
                <button class="btn-close" @onclick="() => _historyVoucher = null"></button>
            </div>
            <div class="modal-body-custom">
                @if (_historyVoucher.Type == VoucherType.Amount)
                {
                    <div class="d-flex gap-4 mb-3 small text-muted">
                        <span>Nominał: <strong class="text-dark">@_historyVoucher.AmountValue?.ToString("F0") PLN</strong></span>
                        <span>Aktualne saldo: <strong class="text-dark">@_historyVoucher.CurrentBalance.ToString("F0") PLN</strong></span>
                        <span>Wykorzystano: <strong class="text-dark">@((_historyVoucher.AmountValue ?? 0) - _historyVoucher.CurrentBalance):F0 PLN</strong></span>
                    </div>
                }
                @if (!_history.Any())
                {
                    <div class="text-muted text-center py-3">Brak historii użycia — voucher nie był jeszcze używany.</div>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Klient</th>
                                <th>Usługa</th>
                                @if (_historyVoucher.Type == VoucherType.Amount)
                                {
                                    <th class="text-end">Odliczone</th>
                                    <th class="text-end">Saldo po</th>
                                }
                                else
                                {
                                    <th>Typ realizacji</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _history)
                            {
                                <tr>
                                    <td>@u.UsedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@u.ClientName</td>
                                    <td>@u.ServiceName</td>
                                    @if (_historyVoucher.Type == VoucherType.Amount)
                                    {
                                        <td class="text-end">
                                            @if (u.AmountDeducted.HasValue)
                                            {
                                                <span class="text-danger">-@u.AmountDeducted.Value.ToString("F0") PLN</span>
                                            }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td class="text-end">
                                            @if (u.BalanceAfter.HasValue)
                                            {
                                                <strong>@u.BalanceAfter.Value.ToString("F0") PLN</strong>
                                            }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                    }
                                    else
                                    {
                                        <td><span class="badge bg-secondary">Zrealizowany</span></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary" @onclick="() => _historyVoucher = null">Zamknij</button>
            </div>
        </div>
    </div>
}

<!-- Modal: formularz vouchera -->
@if (_showForm && _editing != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>@(_editing.Id == 0 ? "Nowy voucher" : "Edytuj voucher")</h5>
                <button class="btn-close" @onclick="CloseForm"></button>
            </div>
            <EditForm Model="_editing" OnValidSubmit="SaveVoucher" FormName="voucher-form">
                <DataAnnotationsValidator />
                <div class="modal-body-custom">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Kod *</label>
                            <div class="input-group">
                                <InputText @bind-Value="_editing.Code" class="form-control" placeholder="np. V-2605-ABCD" />
                                <button type="button" class="btn btn-outline-secondary" @onclick="GenerateCode">Generuj</button>
                            </div>
                            <ValidationMessage For="() => _editing.Code" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Typ</label>
                            <InputSelect @bind-Value="_editing.Type" class="form-select">
                                <option value="@VoucherType.Amount">Kwotowy</option>
                                <option value="@VoucherType.Service">Na usługę</option>
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Klient (odbiorca)</label>
                            <div class="d-flex gap-2">
                                <select class="form-select" value="@_editing.ClientId" @onchange="OnClientSelected">
                                    <option value="">-- wybierz klienta --</option>
                                    @foreach (var c in _clients)
                                    {
                                        <option value="@c.Id">@c.FirstName @c.LastName @(!string.IsNullOrEmpty(c.PhoneNumber) ? $"({c.PhoneNumber})" : "")</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-secondary text-nowrap" @onclick="() => _showQuickClient = true" title="Dodaj nowego klienta">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                            </div>
                        </div>

                        @if (_editing.Type == VoucherType.Amount)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Wartość nominalna (PLN)</label>
                                <InputNumber @bind-Value="_editing.AmountValue" class="form-control" />
                            </div>
                            @if (_editing.Id != 0)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">Saldo (PLN)</label>
                                    <InputNumber @bind-Value="_editing.RemainingAmount" class="form-control" />
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-md-6">
                                <label class="form-label">Usługa / Karnet</label>
                                <select class="form-select" @bind="_editing.ServiceName">
                                    <option value="">-- wybierz usługę --</option>
                                    @foreach (var s in _services)
                                    {
                                        <option value="@s.Name">@s.Name</option>
                                    }
                                    @if (_packages.Any())
                                    {
                                        <option disabled>──── Karnety ────</option>
                                        @foreach (var p in _packages)
                                        {
                                            <option value="@p.Name">@p.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        }

                        <div class="col-md-6">
                            <label class="form-label">Ważny do</label>
                            <InputDate @bind-Value="_editing.ExpiresAt" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notatki</label>
                            <InputTextArea @bind-Value="_editing.Notes" class="form-control" rows="2" />
                        </div>
                        @if (_editing.Id != 0)
                        {
                            <div class="col-12">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_editing.IsUsed" class="form-check-input" id="isUsed" />
                                    <label class="form-check-label" for="isUsed">Oznacz jako w pełni użyty</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer-custom">
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @(_saving ? "Zapisywanie..." : "Zapisz")
                    </button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CloseForm">Anuluj</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Modal: szybkie dodanie klienta -->
@if (_showQuickClient)
{
    <div class="modal-backdrop" style="z-index:1060">
        <div class="modal-dialog-custom" style="max-width:440px">
            <div class="modal-header-custom">
                <h5>Szybkie dodanie klienta</h5>
                <button class="btn-close" @onclick="() => _showQuickClient = false"></button>
            </div>
            <EditForm Model="_quickClient" OnValidSubmit="SaveQuickClient" FormName="quick-client-form">
                <DataAnnotationsValidator />
                <div class="modal-body-custom">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Imię *</label>
                            <InputText @bind-Value="_quickClient.FirstName" class="form-control" />
                            <ValidationMessage For="() => _quickClient.FirstName" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Nazwisko *</label>
                            <InputText @bind-Value="_quickClient.LastName" class="form-control" />
                            <ValidationMessage For="() => _quickClient.LastName" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="_quickClient.PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">E-mail</label>
                            <InputText @bind-Value="_quickClient.Email" class="form-control" />
                            <ValidationMessage For="() => _quickClient.Email" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer-custom">
                    <button type="submit" class="btn btn-primary" disabled="@_quickSaving">
                        @(_quickSaving ? "Zapisywanie..." : "Dodaj klienta")
                    </button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="() => _showQuickClient = false">Anuluj</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Modal: potwierdzenie usunięcia -->
@if (_deleteTarget != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>Usuń voucher</h5>
                <button class="btn-close" @onclick="() => _deleteTarget = null"></button>
            </div>
            <div class="modal-body-custom">
                <p>Czy na pewno chcesz usunąć voucher <strong>@_deleteTarget.Code</strong>?</p>
                <p class="text-muted small">Usunięcie spowoduje również usunięcie historii użycia tego vouchera.</p>
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-danger" @onclick="DeleteConfirmed">Usuń</button>
                <button class="btn btn-secondary ms-2" @onclick="() => _deleteTarget = null">Anuluj</button>
            </div>
        </div>
    </div>
}

@code {
    private List<VoucherEntity> _vouchers = [];
    private List<ClientEntity> _clients = [];
    private List<ServiceEntity> _services = [];
    private List<MembershipPackageEntity> _packages = [];
    private string _filter = "all";
    private string _sortBy = "date";
    private bool _sortDesc = false;
    private bool _loading = true;
    private bool _showForm;
    private VoucherEntity _editing = new();
    private VoucherEntity? _deleteTarget;
    private bool _saving;
    private int _expiringCount;

    private bool _showQuickClient;
    private ClientEntity _quickClient = new();
    private bool _quickSaving;

    private VoucherEntity? _historyVoucher;
    private List<VoucherUseEntity> _history = [];

    private IEnumerable<VoucherEntity> Filtered
    {
        get
        {
            var q = _filter switch
            {
                "active"  => _vouchers.Where(v => v.IsActive),
                "used"    => _vouchers.Where(v => v.IsUsed),
                "expired" => _vouchers.Where(v => v.IsExpired && !v.IsUsed),
                _         => _vouchers.AsEnumerable()
            };

            q = (_sortBy, _sortDesc) switch
            {
                ("client",  false) => q.OrderBy(v => v.RecipientName),
                ("client",  true)  => q.OrderByDescending(v => v.RecipientName),
                ("code",    false) => q.OrderBy(v => v.Code),
                ("code",    true)  => q.OrderByDescending(v => v.Code),
                ("balance", false) => q.OrderBy(v => v.CurrentBalance),
                ("balance", true)  => q.OrderByDescending(v => v.CurrentBalance),
                (_,         false) => q.OrderBy(v => v.ExpiresAt),
                _                  => q.OrderByDescending(v => v.ExpiresAt)
            };

            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var vTask = VoucherService.GetAllAsync();
        var cTask = ClientService.GetAllAsync();
        var sTask = ServiceCrmService.GetAllAsync();
        var pTask = MembershipService.GetAllPackagesAsync();
        var eTask = VoucherService.GetExpiringCountAsync(7);

        await Task.WhenAll(vTask, cTask, sTask, pTask, eTask);

        _vouchers = vTask.Result;
        _clients = cTask.Result;
        _services = sTask.Result;
        _packages = pTask.Result.Where(p => p.IsActive).ToList();
        _expiringCount = eTask.Result;
        _loading = false;
    }

    private async Task LoadVouchers()
    {
        _vouchers = await VoucherService.GetAllAsync();
        _expiringCount = await VoucherService.GetExpiringCountAsync(7);
    }

    private void ToggleSort() => _sortDesc = !_sortDesc;

    private async Task OpenHistory(VoucherEntity v)
    {
        _historyVoucher = v;
        _history = await VoucherService.GetUsageHistoryAsync(v.Id);
    }

    private void OpenCreate()
    {
        _editing = new VoucherEntity { ExpiresAt = DateTime.Now.AddMonths(6) };
        GenerateCode();
        _showForm = true;
    }

    private void OpenEdit(VoucherEntity v)
    {
        _editing = new VoucherEntity
        {
            Id = v.Id,
            Code = v.Code,
            ClientId = v.ClientId,
            RecipientName = v.RecipientName,
            Type = v.Type,
            AmountValue = v.AmountValue,
            RemainingAmount = v.RemainingAmount,
            ServiceName = v.ServiceName,
            ExpiresAt = v.ExpiresAt,
            Notes = v.Notes,
            IsUsed = v.IsUsed,
            UsedAt = v.UsedAt,
            UsedInAppointment = v.UsedInAppointment,
            CreatedAt = v.CreatedAt,
            AppointmentId = v.AppointmentId
        };
        _showForm = true;
    }

    private void CloseForm()
    {
        _showForm = false;
        _editing = new();
    }

    private void GenerateCode()
    {
        var rnd = new Random();
        var suffix = new string(Enumerable.Range(0, 4).Select(_ => (char)('A' + rnd.Next(26))).ToArray());
        _editing.Code = "V-" + DateTime.Now.ToString("yyMM") + "-" + suffix;
    }

    private void OnClientSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id) && id > 0)
        {
            _editing.ClientId = id;
            var client = _clients.FirstOrDefault(c => c.Id == id);
            if (client != null)
                _editing.RecipientName = $"{client.FirstName} {client.LastName}";
        }
        else
        {
            _editing.ClientId = null;
            _editing.RecipientName = string.Empty;
        }
    }

    private async Task SaveQuickClient()
    {
        _quickSaving = true;
        try
        {
            var created = await ClientService.CreateAsync(_quickClient);
            _clients = await ClientService.GetAllAsync();
            _editing.ClientId = created.Id;
            _editing.RecipientName = $"{created.FirstName} {created.LastName}";
            _quickClient = new();
            _showQuickClient = false;
        }
        finally
        {
            _quickSaving = false;
        }
    }

    private async Task SaveVoucher()
    {
        _saving = true;
        try
        {
            if (_editing.Type == VoucherType.Amount && _editing.RemainingAmount == null)
                _editing.RemainingAmount = _editing.AmountValue;

            if (_editing.Id == 0)
                await VoucherService.CreateAsync(_editing);
            else
                await VoucherService.UpdateAsync(_editing);

            CloseForm();
            await LoadVouchers();
        }
        finally
        {
            _saving = false;
        }
    }

    private void ConfirmDelete(VoucherEntity v) => _deleteTarget = v;

    private async Task DeleteConfirmed()
    {
        if (_deleteTarget == null) return;
        await VoucherService.DeleteAsync(_deleteTarget.Id);
        _deleteTarget = null;
        await LoadVouchers();
    }
}
