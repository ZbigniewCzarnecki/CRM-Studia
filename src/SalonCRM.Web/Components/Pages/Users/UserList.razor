@page "/users"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject UserManager<SalonCRM.Web.Data.ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Użytkownicy — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Użytkownicy</h1>
    <button class="btn btn-primary" @onclick="() => _showAddForm = true">+ Dodaj użytkownika</button>
</div>

@if (!string.IsNullOrEmpty(_successMsg))
{
    <div class="alert alert-success alert-dismissible">@_successMsg
        <button type="button" class="btn-close" @onclick="() => _successMsg = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_errorMsg))
{
    <div class="alert alert-danger alert-dismissible">@_errorMsg
        <button type="button" class="btn-close" @onclick="() => _errorMsg = null"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nazwa</th>
                    <th>Email</th>
                    <th>Rola</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in _users)
                {
                    var isLocked = u.User.LockoutEnd.HasValue && u.User.LockoutEnd > DateTimeOffset.UtcNow;
                    var isSelf = u.User.Id == _currentUserId;
                    <tr class="@(isLocked ? "text-muted" : "")">
                        <td>@u.User.DisplayName</td>
                        <td>@u.User.Email</td>
                        <td>
                            @if (!isSelf)
                            {
                                <select class="form-select form-select-sm w-auto" value="@u.Role"
                                        @onchange="e => ChangeRole(u.User, e.Value?.ToString() ?? u.Role)">
                                    <option value="Staff">Staff</option>
                                    <option value="Admin">Admin</option>
                                </select>
                            }
                            else
                            {
                                <span class="badge bg-primary">@u.Role</span>
                            }
                        </td>
                        <td>
                            @if (isLocked)
                            {
                                <span class="badge bg-secondary">Zablokowany</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Aktywny</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (!isSelf)
                            {
                                @if (isLocked)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => SetLocked(u.User, false)">Aktywuj</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => SetLocked(u.User, true)">Zablokuj</button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showAddForm)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>Nowy użytkownik</h5>
                <button class="btn-close" @onclick="() => { _showAddForm = false; _newModel = new(); }"></button>
            </div>
            <EditForm Model="_newModel" OnValidSubmit="CreateUser" FormName="add-user-form">
                <DataAnnotationsValidator />
                <div class="modal-body-custom">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nazwa wyświetlana *</label>
                            <InputText @bind-Value="_newModel.DisplayName" class="form-control" />
                            <ValidationMessage For="() => _newModel.DisplayName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email *</label>
                            <InputText @bind-Value="_newModel.Email" class="form-control" />
                            <ValidationMessage For="() => _newModel.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hasło *</label>
                            <InputText @bind-Value="_newModel.Password" type="password" class="form-control" />
                            <ValidationMessage For="() => _newModel.Password" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Rola</label>
                            <InputSelect @bind-Value="_newModel.Role" class="form-select">
                                <option value="Staff">Staff — pracownik</option>
                                <option value="Admin">Admin — pełny dostęp</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
                <div class="modal-footer-custom">
                    <button type="submit" class="btn btn-primary">Utwórz konto</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="() => { _showAddForm = false; _newModel = new(); }">Anuluj</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private record UserRow(SalonCRM.Web.Data.ApplicationUser User, string Role);

    private List<UserRow> _users = [];
    private string? _currentUserId;
    private bool _showAddForm;
    private string? _successMsg;
    private string? _errorMsg;
    private NewUserModel _newModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = UserManager.GetUserId(authState.User);
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var users = await UserManager.Users.OrderBy(u => u.DisplayName).ToListAsync();
        var rows = new List<UserRow>();
        foreach (var u in users)
        {
            var roles = await UserManager.GetRolesAsync(u);
            rows.Add(new UserRow(u, roles.FirstOrDefault() ?? "—"));
        }
        _users = rows;
    }

    private async Task ChangeRole(SalonCRM.Web.Data.ApplicationUser user, string newRole)
    {
        var currentRoles = await UserManager.GetRolesAsync(user);
        await UserManager.RemoveFromRolesAsync(user, currentRoles);
        await UserManager.AddToRoleAsync(user, newRole);
        _successMsg = $"Rola {user.DisplayName} zmieniona na {newRole}.";
        await LoadUsersAsync();
    }

    private async Task SetLocked(SalonCRM.Web.Data.ApplicationUser user, bool locked)
    {
        await UserManager.SetLockoutEnabledAsync(user, true);
        await UserManager.SetLockoutEndDateAsync(user, locked ? DateTimeOffset.MaxValue : null);
        _successMsg = locked ? $"Konto {user.DisplayName} zablokowane." : $"Konto {user.DisplayName} aktywowane.";
        await LoadUsersAsync();
    }

    private async Task CreateUser()
    {
        _errorMsg = null;
        var user = new SalonCRM.Web.Data.ApplicationUser
        {
            UserName = _newModel.Email,
            Email = _newModel.Email,
            EmailConfirmed = true,
            DisplayName = _newModel.DisplayName
        };
        var result = await UserManager.CreateAsync(user, _newModel.Password);
        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, _newModel.Role);
            _successMsg = $"Konto dla {_newModel.Email} zostało utworzone.";
            _newModel = new();
            _showAddForm = false;
            await LoadUsersAsync();
        }
        else
        {
            _errorMsg = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    private sealed class NewUserModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string DisplayName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = string.Empty;

        public string Role { get; set; } = "Staff";
    }
}
