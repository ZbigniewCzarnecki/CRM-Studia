@page "/users"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject UserManager<SalonCRM.Web.Data.ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IPermissionService PermissionService

<PageTitle>Użytkownicy — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Użytkownicy</h1>
    <button class="btn btn-primary" @onclick="() => _showAddForm = true">+ Dodaj użytkownika</button>
</div>

@if (!string.IsNullOrEmpty(_successMsg))
{
    <div class="alert alert-success alert-dismissible">@_successMsg
        <button type="button" class="btn-close" @onclick="() => _successMsg = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_errorMsg))
{
    <div class="alert alert-danger alert-dismissible">@_errorMsg
        <button type="button" class="btn-close" @onclick="() => _errorMsg = null"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nazwa</th>
                    <th>Email</th>
                    <th>Rola</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in _users)
                {
                    var isLocked = u.User.LockoutEnd.HasValue && u.User.LockoutEnd > DateTimeOffset.UtcNow;
                    var isSelf = u.User.Id == _currentUserId;
                    var isPracownik = u.Role == "Pracownik";
                    var isExpanded = _expandedPerms.Contains(u.User.Id);
                    <tr class="@(isLocked ? "text-muted" : "")">
                        <td>@u.User.DisplayName</td>
                        <td>@u.User.Email</td>
                        <td>
                            @if (!isSelf)
                            {
                                <select class="form-select form-select-sm w-auto" value="@u.Role"
                                        @onchange="e => ChangeRole(u.User, e.Value?.ToString() ?? u.Role)">
                                    <option value="Pracownik">Pracownik</option>
                                    <option value="Admin">Admin</option>
                                </select>
                            }
                            else
                            {
                                <span class="badge bg-primary">@u.Role</span>
                            }
                        </td>
                        <td>
                            @if (isLocked)
                            {
                                <span class="badge bg-secondary">Zablokowany</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Aktywny</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (isPracownik)
                            {
                                <button class="btn btn-sm btn-outline-secondary me-1"
                                        @onclick="() => TogglePerms(u.User.Id)">
                                    @(isExpanded ? "Ukryj uprawnienia" : "Uprawnienia")
                                </button>
                            }
                            @if (!isSelf)
                            {
                                @if (isLocked)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => SetLocked(u.User, false)">Aktywuj</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => SetLocked(u.User, true)">Zablokuj</button>
                                }
                            }
                        </td>
                    </tr>
                    @if (isExpanded && _permsMap.TryGetValue(u.User.Id, out var perms))
                    {
                        <tr>
                            <td colspan="5" class="bg-light p-3">
                                <div class="fw-bold mb-2">Uprawnienia pracownika: @u.User.DisplayName</div>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pma-@u.User.Id"
                                                   checked="@perms.CanManageAppointments"
                                                   @onchange="e => { perms.CanManageAppointments = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pma-@u.User.Id">Zarządzanie wizytami</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pda-@u.User.Id"
                                                   checked="@perms.CanDeleteAppointments"
                                                   @onchange="e => { perms.CanDeleteAppointments = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pda-@u.User.Id">Usuwanie wizyt</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pec-@u.User.Id"
                                                   checked="@perms.CanEditClientData"
                                                   @onchange="e => { perms.CanEditClientData = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pec-@u.User.Id">Edycja danych klientów</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pms-@u.User.Id"
                                                   checked="@perms.CanManageServices"
                                                   @onchange="e => { perms.CanManageServices = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pms-@u.User.Id">Zarządzanie usługami</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pvr-@u.User.Id"
                                                   checked="@perms.CanViewReports"
                                                   @onchange="e => { perms.CanViewReports = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pvr-@u.User.Id">Podgląd przychodów</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pmw-@u.User.Id"
                                                   checked="@perms.CanManageWorkers"
                                                   @onchange="e => { perms.CanManageWorkers = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pmw-@u.User.Id">Zarządzanie pracownikami</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="pset-@u.User.Id"
                                                   checked="@perms.CanManageSettings"
                                                   @onchange="e => { perms.CanManageSettings = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="pset-@u.User.Id">Ustawienia salonu</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="plc-@u.User.Id"
                                                   checked="@perms.CanManageLoyaltyCards"
                                                   @onchange="e => { perms.CanManageLoyaltyCards = (bool)(e.Value ?? false); }" />
                                            <label class="form-check-label" for="plc-@u.User.Id">Karty lojalnościowe</label>
                                        </div>
                                    </div>
                                </div>
                                <button class="btn btn-primary btn-sm mt-3" @onclick="() => SavePerms(u.User.Id)">Zapisz uprawnienia</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showAddForm)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-custom">
            <div class="modal-header-custom">
                <h5>Nowy użytkownik</h5>
                <button class="btn-close" @onclick="() => { _showAddForm = false; _newModel = new(); }"></button>
            </div>
            <EditForm Model="_newModel" OnValidSubmit="CreateUser" FormName="add-user-form">
                <DataAnnotationsValidator />
                <div class="modal-body-custom">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nazwa wyświetlana *</label>
                            <InputText @bind-Value="_newModel.DisplayName" class="form-control" />
                            <ValidationMessage For="() => _newModel.DisplayName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email *</label>
                            <InputText @bind-Value="_newModel.Email" class="form-control" />
                            <ValidationMessage For="() => _newModel.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hasło *</label>
                            <InputText @bind-Value="_newModel.Password" type="password" class="form-control" />
                            <ValidationMessage For="() => _newModel.Password" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Rola</label>
                            <InputSelect @bind-Value="_newModel.Role" class="form-select">
                                <option value="Pracownik">Pracownik</option>
                                <option value="Admin">Admin — pełny dostęp</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
                <div class="modal-footer-custom">
                    <button type="submit" class="btn btn-primary">Utwórz konto</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="() => { _showAddForm = false; _newModel = new(); }">Anuluj</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private record UserRow(SalonCRM.Web.Data.ApplicationUser User, string Role);

    private List<UserRow> _users = [];
    private string? _currentUserId;
    private bool _showAddForm;
    private string? _successMsg;
    private string? _errorMsg;
    private NewUserModel _newModel = new();
    private HashSet<string> _expandedPerms = [];
    private Dictionary<string, SalonCRM.Web.Data.Entities.UserPermissions> _permsMap = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = UserManager.GetUserId(authState.User);
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var users = await UserManager.Users.OrderBy(u => u.DisplayName).ToListAsync();
        var rows = new List<UserRow>();
        foreach (var u in users)
        {
            var roles = await UserManager.GetRolesAsync(u);
            rows.Add(new UserRow(u, roles.FirstOrDefault() ?? "—"));
        }
        _users = rows;

        // Preload permissions for Pracownicy
        foreach (var u in _users.Where(u => u.Role == "Pracownik"))
        {
            if (!_permsMap.ContainsKey(u.User.Id))
                _permsMap[u.User.Id] = await PermissionService.GetOrCreateAsync(u.User.Id);
        }
    }

    private async Task TogglePerms(string userId)
    {
        if (!_expandedPerms.Remove(userId))
        {
            _expandedPerms.Add(userId);
            if (!_permsMap.ContainsKey(userId))
                _permsMap[userId] = await PermissionService.GetOrCreateAsync(userId);
        }
    }

    private async Task SavePerms(string userId)
    {
        if (_permsMap.TryGetValue(userId, out var perms))
        {
            await PermissionService.SaveAsync(perms);
            _successMsg = "Uprawnienia zostały zapisane.";
        }
    }

    private async Task ChangeRole(SalonCRM.Web.Data.ApplicationUser user, string newRole)
    {
        var currentRoles = await UserManager.GetRolesAsync(user);
        await UserManager.RemoveFromRolesAsync(user, currentRoles);
        await UserManager.AddToRoleAsync(user, newRole);
        if (newRole == "Pracownik")
            await PermissionService.GetOrCreateAsync(user.Id);
        _successMsg = $"Rola {user.DisplayName} zmieniona na {newRole}.";
        await LoadUsersAsync();
    }

    private async Task SetLocked(SalonCRM.Web.Data.ApplicationUser user, bool locked)
    {
        await UserManager.SetLockoutEnabledAsync(user, true);
        await UserManager.SetLockoutEndDateAsync(user, locked ? DateTimeOffset.MaxValue : null);
        _successMsg = locked ? $"Konto {user.DisplayName} zablokowane." : $"Konto {user.DisplayName} aktywowane.";
        await LoadUsersAsync();
    }

    private async Task CreateUser()
    {
        _errorMsg = null;
        var user = new SalonCRM.Web.Data.ApplicationUser
        {
            UserName = _newModel.Email,
            Email = _newModel.Email,
            EmailConfirmed = true,
            DisplayName = _newModel.DisplayName
        };
        var result = await UserManager.CreateAsync(user, _newModel.Password);
        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, _newModel.Role);
            if (_newModel.Role == "Pracownik")
                await PermissionService.GetOrCreateAsync(user.Id);
            _successMsg = $"Konto dla {_newModel.Email} zostało utworzone.";
            _newModel = new();
            _showAddForm = false;
            await LoadUsersAsync();
        }
        else
        {
            _errorMsg = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    private sealed class NewUserModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string DisplayName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = string.Empty;

        public string Role { get; set; } = "Pracownik";
    }
}
