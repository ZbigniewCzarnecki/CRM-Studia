@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IClientService ClientService
@inject IServiceCrmService ServiceCrmService
@inject IAppointmentService AppointmentService
@inject IVoucherService VoucherService

<PageTitle>Dashboard — SalonCRM</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <span class="text-muted">@DateTime.Now.ToString("dddd, d MMMM yyyy", new System.Globalization.CultureInfo("pl-PL"))</span>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="stat-value">@_clientCount</div>
        <div class="stat-label">Klientów</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-scissors"></i></div>
        <div class="stat-value">@_serviceCount</div>
        <div class="stat-label">Usług</div>
    </div>
    <div class="stat-card accent">
        <div class="stat-icon"><i class="bi bi-calendar-check-fill"></i></div>
        <div class="stat-value">@_upcomingCount</div>
        <div class="stat-label">Nadchodzących wizyt</div>
    </div>
    <PermissionView Permission="Permission.ViewReports">
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-value">@_revenueToday.ToString("C0", new System.Globalization.CultureInfo("pl-PL"))</div>
            <div class="stat-label">Przychód dziś</div>
        </div>
    </PermissionView>
    <PermissionView Permission="Permission.ViewReports">
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="stat-value">@_revenueMonth.ToString("C0", new System.Globalization.CultureInfo("pl-PL"))</div>
            <div class="stat-label">Przychód w miesiącu</div>
        </div>
    </PermissionView>
    <PermissionView Permission="Permission.ViewReports">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="stat-value">@_completedMonth</div>
            <div class="stat-label">Zrealizowanych w miesiącu</div>
        </div>
    </PermissionView>
</div>

@if (_expiringVouchers.Any())
{
    <div class="alert alert-warning mt-4 d-flex flex-column gap-1">
        <div><i class="bi bi-clock-fill me-2"></i><strong>Vouchery wygasające w ciągu 7 dni: @_expiringVouchers.Count</strong></div>
        <ul class="mb-1">
            @foreach (var v in _expiringVouchers.Take(5))
            {
                <li>
                    <strong>@v.Code</strong> — @v.RecipientName
                    (@(v.Type == VoucherType.Amount ? v.AmountValue + " PLN" : v.ServiceName)),
                    ważny do: <strong>@v.ExpiresAt.ToString("dd.MM.yyyy")</strong>
                    (@v.DaysUntilExpiry dni)
                </li>
            }
        </ul>
        <div><a href="/vouchery" class="btn btn-sm btn-warning">Zarządzaj voucherami</a></div>
    </div>
}

@if (_upcoming.Any())
{
    <div class="card mt-4">
        <div class="card-header">Najbliższe wizyty</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Klient</th>
                        <th>Usługa</th>
                        <th class="text-end">Kwota</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _upcoming)
                    {
                        <tr>
                            <td>@a.Date.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@a.ClientName</td>
                            <td>@a.ServiceName</td>
                            <td class="text-end">@a.TotalAmount.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private int _clientCount, _serviceCount, _upcomingCount, _completedMonth;
    private decimal _revenueToday, _revenueMonth;
    private List<AppointmentEntity> _upcoming = [];
    private List<VoucherEntity> _expiringVouchers = [];

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Now;
        var todayStart = now.Date;
        var todayEnd = todayStart.AddDays(1).AddTicks(-1);
        var monthStart = new DateTime(now.Year, now.Month, 1);
        var monthEnd = monthStart.AddMonths(1).AddTicks(-1);

        var clientsTask = ClientService.GetAllAsync();
        var servicesTask = ServiceCrmService.GetAllAsync();
        var upcomingCountTask = AppointmentService.CountUpcomingAsync();
        var revTodayTask = AppointmentService.GetRevenueAsync(todayStart, todayEnd);
        var revMonthTask = AppointmentService.GetRevenueAsync(monthStart, monthEnd);
        var allTask = AppointmentService.GetAllAsync();
        var expiringTask = VoucherService.GetExpiringAsync(7);

        await Task.WhenAll(clientsTask, servicesTask, upcomingCountTask, revTodayTask, revMonthTask, allTask, expiringTask);

        _clientCount = clientsTask.Result.Count;
        _serviceCount = servicesTask.Result.Count;
        _upcomingCount = upcomingCountTask.Result;
        _revenueToday = revTodayTask.Result;
        _revenueMonth = revMonthTask.Result;
        _expiringVouchers = expiringTask.Result;

        var all = allTask.Result;
        _upcoming = all.Where(a => a.Date >= now).OrderBy(a => a.Date).Take(5).ToList();
        _completedMonth = all.Count(a => a.Status == AppointmentStatus.Completed && a.Date >= monthStart && a.Date <= monthEnd);
    }
}
